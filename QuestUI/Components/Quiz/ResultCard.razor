<article class="card">
    <p class="eyebrow">@ResultsTitle</p>
    <h2>@((MarkupString)Question.Text)</h2>
    <div class="results-chart">
        @foreach (var answer in OrderedAnswers)
        {
            var percentage = GetVotePercentage(answer);

            <div class="result-bar-card @GetAnswerClass(answer.Index) @GetCorrectResultClass(answer)">
                <span class="result-votes">@answer.Votes</span>

                <div class="result-bar-track" aria-hidden="true">
                    <div class="result-bar-fill" style="height: @percentage%;"></div>
                </div>

                <div class="result-answer-copy">
                    <strong>@((MarkupString)answer.Text)</strong>
                    <span class="result-percent">@percentage%</span>
                    @if (!Question.IsSurvey && answer.IsCorrect)
                    {
                        <span class="correct-label">Correct</span>
                    }
                </div>
            </div>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public QuestionView Question { get; set; } = default!;

    [Parameter]
    public bool IsCompleted { get; set; }

    private int TotalVotes => Question.Answers.Sum(answer => answer.Votes);

    private string ResultsTitle => Question.IsSurvey switch
    {
        true => $"Question {Question.Number} survey results",
        false when IsCompleted => "Final results",
        _ => $"Question {Question.Number} results"
    };

    private IEnumerable<AnswerOptionView> OrderedAnswers => Question.Answers.OrderBy(answer => answer.Index);

    private int GetVotePercentage(AnswerOptionView answer)
    {
        if (TotalVotes <= 0)
        {
            return 0;
        }

        return (int)Math.Round(answer.Votes * 100d / TotalVotes, MidpointRounding.AwayFromZero);
    }

    private static string GetAnswerClass(int answerIndex) => $"answer-{answerIndex}";

    private string GetCorrectResultClass(AnswerOptionView answer) => !Question.IsSurvey && answer.IsCorrect
        ? "correct-result"
        : string.Empty;
}
