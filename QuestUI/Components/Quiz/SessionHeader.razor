<header class="card top-bar @(IsCompact ? "top-bar-compact" : string.Empty)">
    <div>
        <p class="eyebrow">Connected as</p>
        <h1>@UserName</h1>
        @if (IsAdmin)
        {
            <span class="badge">admin</span>
        }
    </div>

    <div class="top-bar-actions">
        @if (IsAdmin)
        {
            <button class="danger-button" type="button" @onclick="OnRestart">Restart quest</button>
        }

        <form method="post" action="/auth/logout">
            <button class="secondary-button" type="submit">Leave</button>
        </form>
    </div>
</header>

@code {
    [Parameter, EditorRequired]
    public string UserName { get; set; } = string.Empty;

    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public bool IsCompact { get; set; }

    [Parameter]
    public EventCallback OnRestart { get; set; }
}
