@using Microsoft.Extensions.Options
@using QuestBackend
@inject IOptions<QuestOptions> QuestOptionsAccessor

<section class="card auth-card">
    <div>
        <p class="eyebrow">Solid Quest</p>
        <h1>Join the session</h1>
        <p class="muted">Pick a unique username.</p>
    </div>

    <form method="post" action="/auth/login">
        <label class="field-label" for="username">Username</label>
        <input id="username" name="username" class="text-input" value="@UserName" />
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <p class="error-text">@ErrorMessage</p>
        }
        <button class="primary-button" type="submit">Enter</button>
    </form>
</section>

@code {
    [Parameter]
    public string UserName { get; set; } = string.Empty;

    [Parameter]
    public string ErrorMessage { get; set; } = string.Empty;

}
