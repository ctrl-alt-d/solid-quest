@using System.Globalization
@using System.Net
@using System.Text.RegularExpressions
@implements IDisposable

<section class="card question-card @(IsAdmin ? "question-card-projection" : string.Empty)">
    <div class="question-header">
        <div class="question-copy">
            <p class="eyebrow">Question @Question.Number / @Question.Total</p>
            <h2>@((MarkupString)Question.Text)</h2>
        </div>
        <div>
            @if (GetCountdownState() is { } countdown)
            {
                <div class="countdown-stack">
                    <p class="eyebrow countdown-text">@countdown.RemainingSeconds.ToString(CultureInfo.InvariantCulture)s left</p>
                    <div class="countdown-progress"
                         role="progressbar"
                         aria-label="Remaining answer time"
                         aria-valuemin="0"
                         aria-valuemax="100"
                         aria-valuenow="@countdown.ProgressPercent.ToString(CultureInfo.InvariantCulture)">
                        <div class="countdown-progress-fill @countdown.ProgressClass"
                             style="width: @countdown.ProgressPercent.ToString(CultureInfo.InvariantCulture)%"></div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (IsAdmin)
    {
        <p class="muted projection-status">Players are answering. Results reveal automatically on timeout or when everyone finishes.</p>

        <div class="answers-grid projection-answers-grid" aria-label="Answer options being shown to players">
            @foreach (var answer in Question.Answers.OrderBy(answer => answer.Index))
            {
                <article class="projection-answer-card @GetAnswerClass(answer.Index)"
                         aria-label="@GetAnswerAriaLabel(answer)">
                    <span class="answer-label-badge projection-answer-label">@GetAnswerLabel(answer.Index)</span>
                    <span class="projection-answer-text">@((MarkupString)answer.Text)</span>
                </article>
            }
        </div>
    }
    else if (Question.SelectedAnswer is int selectedAnswer)
    {
        <p class="success-text">You answered option @selectedAnswer. Waiting for reveal.</p>
    }
    else
    {
        <div class="answers-grid">
            @foreach (var answer in Question.Answers.OrderBy(answer => answer.Index))
            {
                <button class="answer-button @GetAnswerClass(answer.Index)"
                        type="button"
                        aria-label="@GetAnswerAriaLabel(answer)"
                        @onclick="() => OnAnswer.InvokeAsync(answer.Index)">
                    <span class="answer-option-label answer-label-badge">@GetAnswerLabel(answer.Index)</span>
                    <span class="player-answer-text">@((MarkupString)answer.Text)</span>
                </button>
            }
        </div>
    }
</section>

@code {
    private Timer? _countdownTimer;

    [Parameter, EditorRequired]
    public QuestionView Question { get; set; } = default!;

    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public EventCallback<int> OnAnswer { get; set; }

    protected override void OnParametersSet()
    {
        if (Question.DeadlineUtc is null)
        {
            StopCountdown();
            return;
        }

        _countdownTimer ??= new Timer(
            _ => _ = InvokeAsync(StateHasChanged),
            null,
            TimeSpan.Zero,
            TimeSpan.FromSeconds(1));
    }

    public void Dispose() => StopCountdown();

    private static string GetAnswerClass(int answerIndex) => $"answer-{answerIndex}";

    private static string GetAnswerLetter(int answerIndex) => answerIndex switch
    {
        1 => "A",
        2 => "B",
        3 => "C",
        4 => "D",
        _ => answerIndex.ToString(CultureInfo.InvariantCulture)
    };

    private static string GetAnswerColorName(int answerIndex) => answerIndex switch
    {
        1 => "Red",
        2 => "Blue",
        3 => "Green",
        4 => "Yellow",
        _ => "Option"
    };

    private static string GetAnswerLabel(int answerIndex) => $"{GetAnswerLetter(answerIndex)} · {GetAnswerColorName(answerIndex)}";

    private static string GetAnswerAriaLabel(AnswerOptionView answer)
    {
        var plainAnswerText = StripHtml(answer.Text);

        return string.IsNullOrWhiteSpace(plainAnswerText)
            ? $"Answer {GetAnswerLetter(answer.Index)}, {GetAnswerColorName(answer.Index)}"
            : $"Answer {GetAnswerLetter(answer.Index)}, {GetAnswerColorName(answer.Index)}: {plainAnswerText}";
    }

    private static string StripHtml(string html) =>
        WebUtility.HtmlDecode(Regex.Replace(html, "<[^>]+>", string.Empty)).Trim();

    private CountdownState? GetCountdownState()
    {
        if (Question.DeadlineUtc is null || Question.TimeoutSeconds is null || Question.TimeoutSeconds <= 0)
        {
            return null;
        }

        var remaining = Question.DeadlineUtc.Value - DateTimeOffset.UtcNow;
        var remainingSeconds = Math.Max(0, (int)Math.Ceiling(remaining.TotalSeconds));
        var progressPercent = Math.Clamp((remaining.TotalSeconds / Question.TimeoutSeconds.Value) * 100d, 0d, 100d);

        return new CountdownState(
            remainingSeconds,
            progressPercent,
            GetProgressClass(progressPercent));
    }

    private static string GetProgressClass(double progressPercent) => progressPercent switch
    {
        > 75d => "countdown-progress-green",
        > 25d => "countdown-progress-blue",
        _ => "countdown-progress-red"
    };

    private void StopCountdown()
    {
        _countdownTimer?.Dispose();
        _countdownTimer = null;
    }

    private sealed record CountdownState(int RemainingSeconds, double ProgressPercent, string ProgressClass);
}
