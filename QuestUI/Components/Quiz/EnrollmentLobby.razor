<section class="enrollment-layout">
    <article class="card enrollment-card">
        <p class="eyebrow">@(Snapshot.Stage == QuizStage.Enrollment ? "Enrollment" : "Ready to Start")</p>
        <h2>@(Snapshot.PlayerCount == 0 ? "Waiting for players" : $"{Snapshot.PlayerCount} player(s) ready")</h2>
        <p class="muted">
            @if (IsAdmin)
            {
                @if (Snapshot.Stage == QuizStage.Enrollment)
                {
                    <span>Load a quest to begin.</span>
                }
                else
                {
                    <span>Start when everyone has joined.</span>
                }
            }
            else
            {
                <span>You're in. Wait for admin to start the quiz.</span>
            }
        </p>

        @if (IsAdmin)
        {
            <div class="lobby-message-stack">
                @if (Snapshot.Stage == QuizStage.Enrollment)
                {
                    <p class="muted">Leave the URL empty to use sample questions.</p>
                }
                else
                {
                    <p class="muted">Quest loaded. Preview questions or start when everyone has joined.</p>
                }
            </div>
            @if (Snapshot.Stage == QuizStage.Enrollment)
            {
                <button class="primary-button" @onclick="OnLoad" disabled="@(!Snapshot.CanLoad)">Load quest</button>
            }
            else
            {
                <button class="primary-button" @onclick="OnStart" disabled="@(!Snapshot.CanStart)">Start session</button>
            }
        }
    </article>

    @if (Snapshot.Stage == QuizStage.AcceptingPlayers && Snapshot.QuestMetadata is not null)
    {
        <article class="card quest-preview-card">
            <p class="eyebrow">Quest Preview</p>
            @if (!string.IsNullOrWhiteSpace(Snapshot.QuestMetadata.Image))
            {
                <img src="@Snapshot.QuestMetadata.Image" 
                     alt="@(Snapshot.QuestMetadata.ImageAlt ?? Snapshot.QuestMetadata.Title)" 
                     class="quest-preview-image" />
            }
            <h2>@Snapshot.QuestMetadata.Title</h2>
            @if (IsAdmin)
            {
                <button class="secondary-button" @onclick="OnPreview">Preview questions</button>
            }
        </article>
    }

    @if (IsAdmin)
    {
        @if (Snapshot.Stage == QuizStage.Enrollment)
        {
            <article class="card settings-card">
                <p class="eyebrow">Settings</p>
                <div class="settings-stack">
                    <label class="field-stack field-stack-wide" for="questions-url">
                        <span class="field-stack-label">Questions URL</span>
                        <input id="questions-url"
                               class="text-input lobby-input"
                               type="url"
                               placeholder="https://example.com/questions.yaml"
                               value="@QuestionsUrl"
                               @oninput="HandleUrlChanged" />
                    </label>

                    <label class="field-stack" for="question-timeout-seconds">
                        <span class="field-stack-label">Answer timeout (seconds)</span>
                        <input id="question-timeout-seconds"
                               class="text-input lobby-input timeout-input"
                               type="number"
                               min="@QuestionTimeoutSettings.MinSeconds"
                               max="@QuestionTimeoutSettings.MaxSeconds"
                               step="1"
                               value="@QuestionTimeoutSeconds"
                               @oninput="HandleTimeoutChanged" />
                    </label>

                    <label class="field-stack field-stack-checkbox" for="progressive-scoring">
                        <input id="progressive-scoring"
                               type="checkbox"
                               checked="@ProgressiveScoring"
                               @onchange="HandleProgressiveScoringChanged" />
                        <span>Progressive scoring</span>
                    </label>
                </div>
            </article>
        }
    }

    <article class="card players-card">
        <p class="eyebrow">Players</p>
        <div class="players-header">
            <h3>@Snapshot.PlayerCount enrolled</h3>
            <span class="badge">@Snapshot.PlayerCount total</span>
        </div>

        @if (Snapshot.EnrolledPlayers.Count == 0)
        {
            <p class="muted">No players enrolled yet.</p>
        }
        else
        {
            <ul class="player-list player-chip-list" aria-label="Enrolled players">
                @foreach (var player in Snapshot.EnrolledPlayers)
                {
                    <li class="player-chip">@player</li>
                }
            </ul>
        }
    </article>
</section>

@code {
    [Parameter, EditorRequired]
    public QuizSessionSnapshot Snapshot { get; set; } = default!;

    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public EventCallback OnLoad { get; set; }

    [Parameter]
    public EventCallback OnStart { get; set; }

    [Parameter]
    public EventCallback OnPreview { get; set; }

    [Parameter]
    public string QuestionsUrl { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> QuestionsUrlChanged { get; set; }

    [Parameter]
    public int QuestionTimeoutSeconds { get; set; } = QuestionTimeoutSettings.DefaultSeconds;

    [Parameter]
    public EventCallback<int> QuestionTimeoutSecondsChanged { get; set; }

    [Parameter]
    public bool ProgressiveScoring { get; set; } = true;

    [Parameter]
    public EventCallback<bool> ProgressiveScoringChanged { get; set; }

    private Task HandleUrlChanged(ChangeEventArgs args)
        => QuestionsUrlChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleTimeoutChanged(ChangeEventArgs args)
        => QuestionTimeoutSecondsChanged.InvokeAsync(int.TryParse(args.Value?.ToString(), out var timeoutSeconds)
            ? timeoutSeconds
            : QuestionTimeoutSeconds);

    private Task HandleProgressiveScoringChanged(ChangeEventArgs args)
        => ProgressiveScoringChanged.InvokeAsync(args.Value is bool value && value);
}
