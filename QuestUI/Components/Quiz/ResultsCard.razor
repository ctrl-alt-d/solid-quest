<article class="card question-card">
    <p class="eyebrow">@(IsCompleted ? "Final results" : $"Question {Question.Number} results")</p>
    <h2>@Question.Text</h2>
    <div class="results-list">
        @foreach (var answer in Question.Answers)
        {
            <div class="result-row @(answer.IsCorrect ? "correct-row" : string.Empty)">
                <div>
                    <strong>@answer.Text</strong>
                    @if (answer.IsCorrect)
                    {
                        <span class="correct-label">Correct</span>
                    }
                </div>
                <span>@answer.Votes vote(s)</span>
            </div>
        }
    </div>

    <div class="explanation-box">
        <p class="eyebrow">Explanation</p>
        <p class="explanation-text">@Question.Explanation</p>
    </div>

    @if (IsAdmin && !IsCompleted)
    {
        <button class="primary-button" @onclick="OnAdvance">
            @(Question.Number == Question.Total ? "Show final leaderboard" : "Next question")
        </button>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public QuestionView Question { get; set; } = default!;

    [Parameter]
    public bool IsAdmin { get; set; }

    [Parameter]
    public bool IsCompleted { get; set; }

    [Parameter]
    public EventCallback OnAdvance { get; set; }
}
