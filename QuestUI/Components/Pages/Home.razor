@page "/"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components
@implements IDisposable
@inject CustomAuthStateProvider AuthProvider
@inject IQuizSessionService QuizSession

<PageTitle>Solid Quest</PageTitle>

@if (!_isAuthenticated)
{
    <div class="page-shell">
        <LoginForm UserName="@_loginUserName"
                   ErrorMessage="@_loginError" />
    </div>
}
else
{
    var snapshot = QuizSession.GetSnapshot(_userName);
    var currentQuestion = snapshot.CurrentQuestion;

    <div class="page-shell @GetPageShellClass(snapshot, currentQuestion)">
        <SessionHeader UserName="@_userName"
                       IsAdmin="@_isAdmin"
                       IsCompact="@IsAdminProjectedQuestion(snapshot, currentQuestion)"
                       OnRestart="HandleRestartAsync" />

        @if (!string.IsNullOrWhiteSpace(_actionError))
        {
            <section class="card error-card">
                @_actionError
            </section>
        }

        @switch (snapshot.Stage)
        {
            case QuizStage.Enrollment:
            case QuizStage.AcceptingPlayers:
                @if (_isPreviewMode && _isAdmin && snapshot.Stage == QuizStage.AcceptingPlayers)
                {
                    var previewQuestion = QuizSession.GetPreviewQuestion(_userName, _previewQuestionIndex);
                    if (previewQuestion is not null)
                    {
                        <section class="card preview-card">
                            <div class="preview-header">
                                <p class="eyebrow">Preview Mode</p>
                                <button class="secondary-button" @onclick="ExitPreviewMode">Exit Preview</button>
                            </div>
                            
                            <QuestionCard Question="@previewQuestion" 
                                          IsAdmin="true" 
                                          IsPreview="true" />

                            <div class="preview-navigation">
                                <button class="secondary-button" 
                                        @onclick="PreviousPreviewQuestion" 
                                        disabled="@(_previewQuestionIndex == 0)">← Previous</button>
                                <span class="preview-counter">@(_previewQuestionIndex + 1) / @QuizSession.GetQuestionCount()</span>
                                <button class="secondary-button" 
                                        @onclick="NextPreviewQuestion" 
                                        disabled="@(_previewQuestionIndex >= QuizSession.GetQuestionCount() - 1)">Next →</button>
                            </div>
                        </section>
                    }
                }
                else
                {
                    <EnrollmentLobby Snapshot="@snapshot"
                                     IsAdmin="@_isAdmin"
                                     QuestionsUrl="@_questionsUrl"
                                     QuestionsUrlChanged="HandleQuestionsUrlChanged"
                                     QuestionTimeoutSeconds="@_questionTimeoutSeconds"
                                     QuestionTimeoutSecondsChanged="HandleQuestionTimeoutChanged"
                                     ProgressiveScoring="@_progressiveScoring"
                                     ProgressiveScoringChanged="HandleProgressiveScoringChanged"
                                     OnLoad="HandleLoadAsync"
                                     OnStart="HandleStartAsync"
                                     OnPreview="EnterPreviewMode" />
                }
                break;

            case QuizStage.QuestionOpen when currentQuestion is not null:
                <QuestionCard Question="@currentQuestion" IsAdmin="@_isAdmin" OnAnswer="HandleAnswerAsync" />
                break;

            case QuizStage.QuestionResults when currentQuestion is not null:
                <section class="results-stack">
                    <ResultCard Question="@currentQuestion"
                                IsCompleted="@(snapshot.Stage == QuizStage.Completed)" />

                    <LeaderboardCard Entries="@snapshot.Leaderboard" 
                                     IsAdmin="@_isAdmin" 
                                     UserName="@_userName" />

                    <ExplainCard Question="@currentQuestion"
                                 IsAdmin="@_isAdmin"
                                 IsCompleted="@(snapshot.Stage == QuizStage.Completed)"
                                 OnAdvance="HandleAdvanceAsync" />
                </section>
                break;

            case QuizStage.Completed:
                <section class="results-stack">
                    <WinnerPodium Entries="@snapshot.Leaderboard" />
                    <LeaderboardCard Entries="@snapshot.Leaderboard" 
                                     IsAdmin="@_isAdmin" 
                                     UserName="@_userName" />
                </section>
                break;
        }
    </div>
}

@code {
    private string _loginUserName = string.Empty;
    private string _loginError = string.Empty;
    private string _actionError = string.Empty;
    private string _questionsUrl = string.Empty;
    private int _questionTimeoutSeconds = QuestionTimeoutSettings.DefaultSeconds;
    private bool _progressiveScoring = true;
    private string _userName = string.Empty;
    private bool _isAuthenticated;
    private bool _isAdmin;
    private bool _isPreviewMode;
    private int _previewQuestionIndex;

    [SupplyParameterFromQuery(Name = "loginError")]
    private string? LoginError { get; set; }

    [SupplyParameterFromQuery(Name = "username")]
    private string? LoginUserName { get; set; }

    protected override async Task OnInitializedAsync()
    {
        QuizSession.StateChanged += HandleQuizSessionChanged;

        var authenticationState = await AuthProvider.GetAuthenticationStateAsync();
        UpdateUser(authenticationState.User);
        SyncLoginFormFromQuery();
    }

    public void Dispose()
    {
        QuizSession.StateChanged -= HandleQuizSessionChanged;
    }

    private async Task HandleLoadAsync()
    {
        var result = await QuizSession.TryLoadQuestAsync(_userName, _questionsUrl);

        if (!result.Success)
        {
            _actionError = result.ErrorMessage;
        }
        else
        {
            _actionError = string.Empty;
        }
    }

    private async Task HandleStartAsync()
    {
        var result = await QuizSession.TryStartAsync(_userName, _questionTimeoutSeconds, _progressiveScoring);

        if (!result.Success)
        {
            _actionError = result.ErrorMessage;
        }
        else
        {
            _actionError = string.Empty;
        }
    }

    private Task HandleQuestionsUrlChanged(string questionsUrl)
    {
        _questionsUrl = questionsUrl;
        return Task.CompletedTask;
    }

    private Task HandleQuestionTimeoutChanged(int questionTimeoutSeconds)
    {
        _questionTimeoutSeconds = questionTimeoutSeconds;
        return Task.CompletedTask;
    }

    private Task HandleProgressiveScoringChanged(bool progressiveScoring)
    {
        _progressiveScoring = progressiveScoring;
        return Task.CompletedTask;
    }

    private Task HandleAnswerAsync(int answerIndex)
    {
        if (!QuizSession.TrySubmitAnswer(_userName, answerIndex, out var errorMessage))
        {
            _actionError = errorMessage;
        }
        else
        {
            _actionError = string.Empty;
        }

        return Task.CompletedTask;
    }

    private Task HandleAdvanceAsync()
    {
        if (!QuizSession.TryAdvance(_userName, out var errorMessage))
        {
            _actionError = errorMessage;
        }
        else
        {
            _actionError = string.Empty;
        }

        return Task.CompletedTask;
    }

    private Task HandleRestartAsync()
    {
        if (!QuizSession.TryRestart(_userName, out var errorMessage))
        {
            _actionError = errorMessage;
        }
        else
        {
            _actionError = string.Empty;
        }

        return Task.CompletedTask;
    }

    private void HandleQuizSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void EnterPreviewMode()
    {
        _isPreviewMode = true;
        _previewQuestionIndex = 0;
    }

    private void ExitPreviewMode()
    {
        _isPreviewMode = false;
        _previewQuestionIndex = 0;
    }

    private void PreviousPreviewQuestion()
    {
        if (_previewQuestionIndex > 0)
        {
            _previewQuestionIndex--;
        }
    }

    private void NextPreviewQuestion()
    {
        var questionCount = QuizSession.GetQuestionCount();
        if (_previewQuestionIndex < questionCount - 1)
        {
            _previewQuestionIndex++;
        }
    }

    private void UpdateUser(ClaimsPrincipal user)
    {
        _isAuthenticated = user.Identity?.IsAuthenticated == true;
        _userName = user.Identity?.Name ?? string.Empty;
        _isAdmin = user.IsInRole("Admin");

        if (!_isAuthenticated)
        {
            _actionError = string.Empty;
        }
    }

    private string GetPageShellClass(QuizSessionSnapshot snapshot, QuestionView? currentQuestion) =>
        IsAdminProjectedQuestion(snapshot, currentQuestion) ? "projection-shell" : string.Empty;

    private bool IsAdminProjectedQuestion(QuizSessionSnapshot snapshot, QuestionView? currentQuestion) =>
        _isAdmin && snapshot.Stage == QuizStage.QuestionOpen && currentQuestion is not null;

    private void SyncLoginFormFromQuery()
    {
        if (_isAuthenticated)
        {
            _loginError = string.Empty;
            _loginUserName = string.Empty;
            return;
        }

        _loginError = LoginError ?? string.Empty;
        _loginUserName = LoginUserName ?? string.Empty;
    }
}
